package soul.view
{
   public class AlignPosition
   {
      
      public var left:Number;
      
      public var right:Number;
      
      public var top:Number;
      
      public var bottom:Number;
      
      public function AlignPosition(left:Number = NaN, right:Number = NaN, top:Number = NaN, bottom:Number = NaN)
      {
         super();
         this.left = left;
         this.right = right;
         this.top = top;
         this.bottom = bottom;
      }
   }
}

